# DocHub Configuration
# Copy this file to .env and update with your values

# Organization details
ORG_NAME="Sua Empresa"
SITE_TITLE="DocHub"
BASE_URL="https://docs.suaempresa.com"
GITHUB_REPO="https://github.com/your-org/docs-hub"

# Internationalization (i18n)
# Primary language code (e.g., pt-br, en-us, es-es)
LANGUAGE_CODE="pt-br"
# Supported languages: comma-separated language codes
# Main content will be in LANGUAGE_CODE, others are available via /lang-code/ prefix
SUPPORTED_LANGUAGES="pt-br"

# Netlify (for deployment)
NETLIFY_SITE_ID=""
NETLIFY_AUTH_TOKEN=""
